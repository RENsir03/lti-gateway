APP_NAME="LTI Gateway"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8081
APP_TIMEZONE=Asia/Shanghai

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=30

DB_CONNECTION=pgsql
DB_HOST=lti_gateway_db
DB_PORT=5432
DB_DATABASE=lti_gateway
DB_USERNAME=lti_gateway_user
DB_PASSWORD=lti_gateway_password_123

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=lti_gateway_redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@university.edu"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# LTI Gateway 专用配置
# ============================================

# 默认虚拟邮箱域名
DEFAULT_VIRTUAL_EMAIL_DOMAIN=proxy.university.edu

# LTI 安全配置
LTI_ENCRYPTION_KEY=
LTI_TOKEN_TTL=600
LTI_MAX_LAUNCH_AGE=3600

# 下游 Moodle 配置
MOODLE_BASE_URL=http://moodle:8080
MOODLE_API_TIMEOUT=30
MOODLE_MAX_RETRY=3
MOODLE_WEBSERVICE_TOKEN=

# 日志保留天数
LAUNCH_LOG_RETENTION_DAYS=90

# 速率限制 (每分钟请求数)
RATE_LIMIT_PER_MINUTE=60

# Sentry 错误监控 (可选)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================
# 健康检查配置
# ============================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=60
